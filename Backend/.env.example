# =========================
# Database (PostgreSQL)
# =========================
# Prisma uses the pooled runtime URL; CLI/migrations use DIRECT_URL.
DATABASE_URL=postgresql://postgres:my_local_password@localhost:15432/online_auction_test?schema=public
DIRECT_URL=postgresql://postgres:my_local_password@localhost:15432/online_auction_test?schema=public
# Production Configuration (e.g. Supabase, Neon)
# DATABASE_URL=postgresql://...pooler...?pgbouncer=true&schema=public
# DIRECT_URL=postgresql://...direct-host.../postgres?schema=public

# =========================
# Redis
# =========================
# Local: redis://localhost:16379
# Production: rediss://default:password@endpoint.upstash.io:6379
REDIS_URL=redis://localhost:16379

# =========================
# Kafka
# =========================
KAFKA_BROKERS=localhost:19094
KAFKA_USERNAME=
KAFKA_PASSWORD=

# =========================
# RabbitMQ
# =========================
# Local: amqp://localhost:5672
# Production: amqps://user:password@host/vhost
RABBITMQ_URL=amqp://localhost:5672

# =========================
# Gmail (SMTP)
# =========================
GMAIL_ADDRESS=your_gmail_address
GMAIL_APP_PASSWORD=your_gmail_app_password

# =========================
# Cloudinary
# =========================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# =========================
# JWT
# =========================
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
CSRF_SECRET=use_a_long_random_secret_distinct_from_jwt_secrets

# =========================
# CAPTCHA
# =========================
CAPTCHA_SECRET_KEY=your_captcha_secret_key

# =========================
# Google OAuth (backend-only client ID used to verify ID tokens)
# =========================
GOOGLE_CLIENT_ID=your_google_client_id

# =========================
# Client
# =========================
CLIENT_URL=http://localhost:5173
NODE_ENV=development
PORT=5000
API_DOMAIN=api.example.com

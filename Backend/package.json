{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx watch src/worker.ts",
    "start:prod": "tsx src/server.ts",
    "worker:prod": "tsx src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "watch": "tsc -w",
    "test:connections": "tsx src/test-connections.ts",
    "migrate:latest": "knex --knexfile knexfile.cjs migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.cjs migrate:rollback",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "format": "prettier --write src prisma",
    "format:check": "prettier --check src prisma",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:integration": "vitest run --passWithNoTests",
    "test:concurrency": "vitest run --passWithNoTests"
  },
  "author": "",
  "license": "ISC",
  "description": "",
